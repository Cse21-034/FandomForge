# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/database
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=password
PGDATABASE=fandomforge

# Authentication
JWT_SECRET=your-super-secret-key-change-this-in-production-at-least-32-chars

# Session
SESSION_SECRET=your-session-secret-key

# Frontend URL (for CORS in production)
FRONTEND_URL=https://your-vercel-app.vercel.app

# API URL (for frontend)
VITE_API_URL=http://localhost:5000

# Cloudinary (for video and image storage)
# Videos are uploaded directly to Cloudinary from the frontend
# Setup: Create an unsigned upload preset named "fandomforge_preset" in your Cloudinary dashboard
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Stripe (for payments and subscriptions)
STRIPE_PUBLIC_KEY=pk_test_your_test_key
STRIPE_SECRET_KEY=sk_test_your_test_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Optional: PayPal (if using PayPal instead of Stripe)
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret

# Node Environment
NODE_ENV=development
